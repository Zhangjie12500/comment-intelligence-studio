# ViewLens 环境变量配置

# ============================================
# 必需配置
# ============================================

# OpenAI API 密钥（用于 AI 分析功能）
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# 可选配置
# ============================================

# OpenAI API 中转地址（如果使用中转服务）
OPENAI_BASE_URL=https://turingai.plus/v1

# OpenAI 模型（默认 gpt-4o-mini）
OPENAI_MODEL=gpt-4o-mini

# B站 Cookie（用于抓取 B站评论）
# 获取方法：登录 B站 → F12 → Application → Cookies → 找到 buvid3
BILIBILI_COOKIE=buvid3=your-bilibili-cookie-here

# YouTube API 密钥（用于抓取 YouTube 评论）
# 获取方法：Google Cloud Console → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key-here

# ============================================
# CORS 配置
# ============================================

# 允许的前端域名，逗号分隔
# 生产环境必须包含你的 Vercel 前端地址
# 本地开发包含 localhost 地址
CORS_ORIGINS=https://comment-intelligence-studio-zhangjie12500s-projects.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# ============================================
# 不需要修改
# ============================================

# Render 会自动提供 PORT 环境变量
# PORT=10000
