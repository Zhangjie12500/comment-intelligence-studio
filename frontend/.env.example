# ViewLens 前端环境变量

# ============================================
# API 配置
# ============================================

# 后端 API 地址（必须包含 /api 后缀）
# 本地开发使用本地后端
VITE_API_BASE_URL=http://localhost:8010/api

# ============================================
# 说明
# ============================================

# 开发环境 (.env.development):
# VITE_API_BASE_URL=http://localhost:8010/api

# 生产环境 (.env.production):
# 部署到 Vercel 后，需要在 Vercel 控制台设置此环境变量
# VITE_API_BASE_URL=https://your-render-backend.onrender.com/api
