# ──────────────────────────────────────────────
# 本地开发 / Local Development
# ──────────────────────────────────────────────
# B站 Cookie（必须，用于获取评论数据）
BILIBILI_COOKIE=your_bilibili_cookie_here

# YouTube API Key（必须，用于获取 YouTube 评论）
# 申请地址：https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# OpenAI API Key（可选，用于 AI 分析总结）
# 如果不设置，将使用本地规则生成分析报告
OPENAI_API_KEY=your_openai_api_key

# ──────────────────────────────────────────────
# 部署 / Deployment
# ──────────────────────────────────────────────
# 允许的 CORS 来源（部署后替换为你的前端 URL，多个用逗号分隔）
# CORS_ORIGINS=https://your-app.vercel.app
